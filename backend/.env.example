APP_NAME="JustHolistics"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────
# Default: SQLite (easiest for local dev)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL (uncomment for production or local MySQL)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=justholistics
# DB_USERNAME=root
# DB_PASSWORD=

# ─── Cache / Session ──────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Typesense ────────────────────────────────────────────────
TYPESENSE_HOST=x32yfd6mhrs4nvb5p-1.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=XE7Wrc3WU8JNehnUH3QpcEqpG4xp6wvg
TYPESENSE_SEARCH_ONLY_KEY=I2KxztOF7xCHq9IuhvEwEurIhwqH0Yco

# ─── CORS ─────────────────────────────────────────────────────
# Set this to your Vercel frontend URL after deploying
# e.g. FRONTEND_URL=https://justholistics.vercel.app
FRONTEND_URL=http://localhost:3000

